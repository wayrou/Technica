{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Technica",
  "version": "0.1.0",
  "identifier": "com.chaoscore.technica",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:1430",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Technica",
        "width": 1520,
