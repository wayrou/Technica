{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Technica",
  "version": "1.2.2",
  "identifier": "com.chaoscore.technica",
  "build": {
    "beforeDevCommand": {
      "script": "npm run dev:desktop:server",
      "wait": false
    },
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:1430",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Technica",
        "width": 1520,
        "height": 980,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": [
          "$HOME/**"
        ]
      }
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "targets": [
      "nsis"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEQyNzgwQUU3Q0UxQUMwQkIKUldTN3dCck81d3A0MHRDYUhmRHpqQlZuc3JnSU5aVlRHRllvK1hPcGd3NC9LVDlUUnduVmt4cFIK",
      "endpoints": [
        "https://github.com/wayrou/Technica/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
