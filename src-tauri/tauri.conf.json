{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Technica",
  "version": "1.1.0",
  "identifier": "com.chaoscore.technica",
  "build": {
    "beforeDevCommand": {
      "script": "npm run dev:desktop:server",
      "wait": false
    },
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:1430",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Technica",
        "width": 1520,
        "height": 980,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": [
          "$HOME/**"
        ]
      }
    }
  },
  "bundle": {
    "active": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "targets": [
      "nsis"
    ]
  }
}
